# Example environment variables for CRM Local MVP
# Copy to .env and fill values for local development

# Django
DJANGO_SECRET_KEY=changeme_replace_in_production
DJANGO_DEBUG=1

# Database (examples):
# SQLite (local dev): sqlite:///db.sqlite3
# Postgres example: postgres://user:password@localhost:5432/core_local
DATABASE_URL=sqlite:///db.sqlite3

# Hosts and ports
ALLOWED_HOSTS=localhost,127.0.0.1
PORT=9090

# Optional
EMAIL_HOST=localhost
EMAIL_PORT=1025
